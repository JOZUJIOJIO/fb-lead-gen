# ============================================
# LeadFlow AI 环境变量模板
# Environment Variables Template
# ============================================

# === 数据库 / Database ===
DATABASE_URL=postgresql+asyncpg://leadflow:leadflow123@postgres:5432/leadflow
REDIS_URL=redis://redis:6379/0

# === AI 配置 / AI Configuration ===
AI_PROVIDER=openai              # openai | anthropic | kimi
OPENAI_API_KEY=sk-xxx           # OpenAI API Key (也支持兼容API / also supports compatible APIs)
# OPENAI_BASE_URL=              # 可选：兼容API地址 / Optional: compatible API base URL
# ANTHROPIC_API_KEY=            # Anthropic Claude API Key
# KIMI_API_KEY=                 # Moonshot Kimi API Key

# === 发送控制 / Send Control ===
SEND_INTERVAL_MIN=60            # 消息间隔最小秒数 / Min seconds between messages
SEND_INTERVAL_MAX=180           # 消息间隔最大秒数 / Max seconds between messages
MAX_DAILY_MESSAGES=50           # 每日发送上限 / Daily message limit

# === 代理 / Proxy (可选 / Optional) ===
# PROXY_SERVER=http://127.0.0.1:7890

# === 管理员 / Admin ===
ADMIN_PASSWORD=admin123456      # 管理后台密码 / Admin dashboard password
