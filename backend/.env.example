# LeadFlow AI - Environment Variables
# Copy this file to .env and fill in your values.
# Or run `bash setup.sh` for guided setup.

# ---- Security ----
# SECRET_KEY=your-secret-key-here
ADMIN_PASSWORD=admin123456

# ---- Database (Docker internal, no need to change) ----
DATABASE_URL=postgresql+asyncpg://leadflow:leadflow123@postgres:5432/leadflow
REDIS_URL=redis://redis:6379/0

# ---- AI Provider: openai | anthropic | kimi | openrouter ----
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
KIMI_API_KEY=
OPENROUTER_API_KEY=

# ---- Browser Proxy (optional) ----
PROXY_SERVER=

# ---- Message Sending Limits ----
SEND_INTERVAL_MIN=60
SEND_INTERVAL_MAX=180
MAX_DAILY_MESSAGES=50

# ---- Auto-Reply ----
AUTO_REPLY_ENABLED=True
AUTO_REPLY_INTERVAL=3600
AUTO_REPLY_MAX_ROUNDS=10
