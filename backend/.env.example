DATABASE_URL=postgresql://leadflow:leadflow_dev_password@localhost:5432/leadflow
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-this-to-a-random-string

# AI Provider: kimi (国内推荐) / openai (海外推荐) / anthropic
AI_PROVIDER=kimi

# Kimi K2.5 (月之暗面 — 国内用户推荐，性价比最高)
KIMI_API_KEY=sk-xxx
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5

# OpenAI GPT-5.4 (海外用户推荐)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=

# WhatsApp
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Facebook Graph API (experimental)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
