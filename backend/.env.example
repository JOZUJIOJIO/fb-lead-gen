DATABASE_URL=postgresql://leadflow:leadflow_dev_password@localhost:5432/leadflow
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-this-to-a-random-string

# AI Provider: kimi (国内推荐) / openai (海外推荐) / openrouter (多模型聚合) / anthropic
AI_PROVIDER=kimi

# Kimi K2.5 (月之暗面 — 国内用户推荐，性价比最高)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5

# OpenAI GPT (海外用户推荐)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (多模型聚合平台，支持GPT/Claude/Llama等)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=

# WhatsApp Business API (optional)
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# Facebook Graph API (experimental)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=

# Admin account password (default: admin123456)
ADMIN_PASSWORD=admin123456
