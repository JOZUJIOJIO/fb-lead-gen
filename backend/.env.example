# LeadFlow AI - Environment Variables
# Copy this file to .env and fill in your values.

# ---- Security ----
# SECRET_KEY: Used for JWT signing. Auto-generated if not set.
# SECRET_KEY=your-secret-key-here

# Admin account password (default: admin123456)
# ADMIN_PASSWORD=admin123456

# ---- Database ----
# PostgreSQL connection string (asyncpg driver)
# DATABASE_URL=postgresql+asyncpg://leadflow:leadflow123@postgres:5432/leadflow

# ---- Redis ----
# Redis connection string for Celery broker and caching
# REDIS_URL=redis://redis:6379/0

# ---- AI Provider ----
# Which AI provider to use: openai | anthropic | kimi
# AI_PROVIDER=openai

# OpenAI API key (also works with compatible APIs like DeepSeek, etc.)
# OPENAI_API_KEY=sk-...

# Optional: override OpenAI base URL for compatible APIs
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...

# Kimi (Moonshot) API key
# KIMI_API_KEY=...

# ---- Browser Automation ----
# HTTP/SOCKS proxy for Patchright browser (optional)
# PROXY_SERVER=http://user:pass@proxy:8080

# ---- Message Sending Limits ----
# Min/max seconds to wait between sending messages
# SEND_INTERVAL_MIN=60
# SEND_INTERVAL_MAX=180

# Maximum messages to send per day per account
# MAX_DAILY_MESSAGES=50
